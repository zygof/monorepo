# ── Base de données ──────────────────────────────────────────────────
# PostgreSQL via docker-compose.dev.yml (port 5433)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/marryhair?schema=public"

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6380"

# ── Auth (next-auth v5) ─────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3001"

# ── Google OAuth (optionnel en dev) ──────────────────────────────────
# Mettre à "true" une fois les credentials Google configurées
NEXT_PUBLIC_GOOGLE_ENABLED="false"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ── Resend (emails transactionnels) ──────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Beauté Créole <noreply@beautecreole.re>"

# ── Uploadthing (uploads fichiers/images) ────────────────────────────
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# ── Google Tag Manager (analytics + consent mode v2) ──────────────────
# Créer un conteneur GTM sur https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=""

# ── Sentry (error tracking + performance) ─────────────────────────────
# Laisser vide pour désactiver. Actif uniquement en production.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# CI/CD uniquement — upload sourcemaps
# SENTRY_AUTH_TOKEN=""

# ── Stripe (Premium uniquement — acompte à la réservation) ────────
# Requis uniquement si NEXT_PUBLIC_OFFER_TIER="premium"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Acompte (Premium) ────────────────────────────────────────────
# Pourcentage de l'acompte (défaut: 30)
# NEXT_PUBLIC_DEPOSIT_PERCENTAGE="30"
# Montant minimum en euros (défaut: 5)
# NEXT_PUBLIC_DEPOSIT_MIN_EUROS="5"

# ── Offre MARRYNOV ──────────────────────────────────────────────────
# vitrine  = site vitrine (présence digitale, contact uniquement)
# standard = vitrine + réservation RDV, admin, staff, fidélisation
# premium  = standard + paiement en ligne (acompte Stripe)
NEXT_PUBLIC_OFFER_TIER="standard"

# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_SALON_NAME="Beauté Créole"
