# n8n — automatisation (optionnel, dégradation gracieuse si absent)
# Local  : http://n8n.localhost/webhook/nouveau-lead
# Prod   : https://n8n.marrynov.re/webhook/nouveau-lead
N8N_WEBHOOK_NOUVEAU_LEAD=

# Resend — emails formulaire de contact
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=nicolas@marrynov.re
CONTACT_FROM_EMAIL=contact@marrynov.re

# Sentry (monitoring erreurs)
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Pour l'upload de sourcemaps en CI
SENTRY_ORG=marrynov
SENTRY_PROJECT=marrynov-site
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxx

# Analytics (Google Tag Manager + GA4)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Google Ads — suivi des conversions (optionnel, par client)
NEXT_PUBLIC_GADS_CONVERSION_ID=AW-XXXXXXXXX
NEXT_PUBLIC_GADS_CONVERSION_LABEL=xxxxxxxxxxxx

# GA4 Data API — dashboard admin (compte de service Google Cloud)
# Récupérer via Google Cloud Console → IAM → Comptes de service
GA4_PROPERTY_ID=properties/XXXXXXXXX
GA4_SERVICE_ACCOUNT_EMAIL=ga4-readonly@projet.iam.gserviceaccount.com
# JSON stringifié du fichier de clé du compte de service
GA4_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"..."}

# URL production
NEXT_PUBLIC_SITE_URL=https://marrynov.re
