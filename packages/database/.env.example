# ── PostgreSQL (docker-compose.dev.yml) ───────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Port 5433 pour ne pas confliter avec n8n (5432)
DATABASE_URL="postgresql://marrynov:marrynov@localhost:5433/marryhair?schema=public"

# ── Redis (docker-compose.dev.yml) ────────────────────────────────────
# Port 6380 pour ne pas confliter avec un éventuel Redis système
REDIS_URL="redis://localhost:6380"
